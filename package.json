{
  "name": "@deotio/cdk-grafana",
  "version": "0.1.1",
  "description": "AWS CDK constructs for deploying and managing AWS Managed Grafana workspaces",
  "main": "dist/lib/index.js",
  "types": "dist/lib/index.d.ts",
  "files": [
    "dist/lib/**/*.js",
    "dist/lib/**/*.d.ts",
    "dist/lib/**/*.d.ts.map"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "lint": "eslint 'lib/**/*.ts' 'test/**/*.ts'",
    "prepublishOnly": "npm run build && npm run test"
  },
  "peerDependencies": {
    "aws-cdk-lib": "^2.100.0",
    "cdk-nag": "^2.0.0",
    "constructs": "^10.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "aws-cdk-lib": "^2.100.0",
    "cdk-nag": "^2.0.0",
    "constructs": "^10.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "aws",
    "cdk",
    "grafana",
    "managed-grafana",
    "observability",
    "infrastructure-as-code"
